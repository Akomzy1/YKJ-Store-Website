# ─── YKJ Store — Environment Variables ───────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key   # SERVER ONLY — never expose to browser

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...                               # SERVER ONLY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...                             # From: stripe listen --forward-to localhost:3000/api/webhook

# ─── Resend (Email) ──────────────────────────────────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_...                                       # SERVER ONLY

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000                  # Production: https://ykjfoodstore.co.uk
